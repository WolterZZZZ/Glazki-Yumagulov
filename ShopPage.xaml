<Page x:Class="Юмагулов_Глазки_save.ShopPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Юмагулов_Глазки_save"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ShopPage">

    <Grid>
        <ListView Name="ServiceListView" >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <Image Width="100" Grid.Column="0" Stretch="UniformToFill"
                   HorizontalAlignment="Center">
                <Image.Source>
                    <Binding Path="MainImagePath">
                        <Binding.TargetNullValue>
                            <ImageSource>
                                Res/picture.png
                            </ImageSource>
                        </Binding.TargetNullValue>
                    </Binding>
                </Image.Source>
            </Image>
            <TextBlock Text="{Binding Title}" Grid.Column="1" Grid.Row="0" HorizontalAlignment="Left"
                       FontSize="20" TextWrapping="Wrap"></TextBlock>
            <TextBlock Text="{Binding C}" Grid.Column="1" Grid.Row="1" HorizontalAlignment="Left"
           FontSize="20"></TextBlock>
            <TextBlock Grid.Column="1" Grid.Row="1" HorizontalAlignment="Right"
           FontSize="20"></TextBlock>
            <TextBlock Grid.Column="1" Grid.Row="2" HorizontalAlignment="Left"
           FontSize="16"></TextBlock>
        </ListView>

    </Grid>
</Page>
