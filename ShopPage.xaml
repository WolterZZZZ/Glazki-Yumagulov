<Page x:Class="Юмагулов_Глазки_save.ShopPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Юмагулов_Глазки_save"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ShopPage" FontFamily="Century Gothic" IsVisibleChanged="Page_IsVisibleChanged" >
    <Page.Resources>
        <local:DiscountColorConverter x:Key="discountColorConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto" MinWidth="208"/>
                <ColumnDefinition Width="Auto" MinWidth="113"/>
                <ColumnDefinition Width="Auto" MinWidth="235"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TBoxSearch" TextChanged="TBoxSearch_TextChanged" Margin="0,0,10,0" VerticalAlignment="Center" Height="16"/>
            <ComboBox Grid.Column="1" x:Name="ComboSort" SelectionChanged="ComboSort_SelectionChanged" VerticalAlignment="Center" Height="20" HorizontalAlignment="Center" Width="164">
                <ComboBoxItem Content="Без сортировки"/>
                <ComboBoxItem Content="Наименование (А-Я)"/>
                <ComboBoxItem Content="Наименование (Я-А)"/>
                <ComboBoxItem Content="Приоритет (возрастание)"/>
                <ComboBoxItem Content="Приоритет (убывание)"/>
                <ComboBoxItem Content="Скидка (возрастание)"/>
                <ComboBoxItem Content="Скидка (убывание)"/>
            </ComboBox>
            <ComboBox Grid.Column="2" x:Name="ComboFilter" SelectionChanged="ComboFilter_SelectionChanged" DisplayMemberPath="Title" Margin="5,0,5,0" VerticalAlignment="Center" Height="20"/>
            <Button Grid.Column="3" Content="Добавить агента" x:Name="BtnAdd" Click="BtnAdd_Click" Padding="15,0" VerticalAlignment="Center" Height="30" Margin="30,0,0,0" HorizontalAlignment="Left" Width="205"/>
        </Grid>

        <ListView x:Name="AgentListView" Grid.Row="1" HorizontalContentAlignment="Stretch" Margin="10,0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="10"
                            Background="{Binding DiscountPercent, Converter={StaticResource discountColorConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Width="100" Height="100" Stretch="Uniform">
                                <Image.Source>
                                    <Binding Path="Logo">
                                        <Binding.TargetNullValue>
                                            <BitmapImage UriSource="Res/picture.png" />
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </Image.Source>
                            </Image>
                            <StackPanel Grid.Column="1" Margin="10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding AgentType.Title}" FontSize="18"/>
                                    <TextBlock Text=" | " FontSize="18"/>
                                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock Text="{Binding TotalSales, StringFormat='{}{0} продаж за год'}" Margin="0,5"/>
                                <TextBlock Text="{Binding Phone}"/>
                                <TextBlock Text="{Binding Priority, StringFormat='Приоритетность: {0}'}" Margin="0,5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DiscountPercent, StringFormat='{}{0}%'}" FontSize="20" HorizontalAlignment="Right"/>
                                <Button Content="Редактировать" Margin="0,15,0,0" x:Name="BtnEdit" Click="BtnEdit_Click" Padding="10,2"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2" Margin="10">
            <Button x:Name="BtnChangePriority" 
                    Content="Изменить приоритет" 
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Width="256" Padding="10,0"
                    Background="#B175EE"
                    Click="BtnChangePriority_Click" Margin="5,0,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock x:Name="TextBlockPageInfo" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button x:Name="BtnPrev" Content="&lt;" Click="BtnPrev_Click" Width="30" Height="30" Margin="2"/>
                <StackPanel x:Name="StackPanelPages" Orientation="Horizontal"/>
                <Button x:Name="BtnNext" Content="&gt;" Click="BtnNext_Click" Width="30" Height="30" Margin="2"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>