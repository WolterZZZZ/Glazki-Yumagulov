<Page x:Class="Юмагулов_Глазки_save.ShopPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Юмагулов_Глазки_save"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ShopPage" FontFamily="Century Gothic">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBox Width="300" x:Name="TBoxSearch" TextChanged="TBoxSearch_TextChanged" Margin="0,0,10,0" />
            <ComboBox Width="150" x:Name="ComboSort" SelectionChanged="ComboSort_SelectionChanged" Margin="0,0,10,0">
                <ComboBoxItem Content="Без сортировки"/>
                <ComboBoxItem Content="Наименование (А-Я)"/>
                <ComboBoxItem Content="Наименование (Я-А)"/>
                <ComboBoxItem Content="Приоритет (возрастание)"/>
                <ComboBoxItem Content="Приоритет (убывание)"/>
                <ComboBoxItem Content="Скидка (возрастание)"/>
                <ComboBoxItem Content="Скидка (убывание)"/>
            </ComboBox>
            <ComboBox Width="150" x:Name="ComboFilter" SelectionChanged="ComboFilter_SelectionChanged" DisplayMemberPath="Title"/>
        </StackPanel>

        <ListView x:Name="AgentListView" Grid.Row="1" HorizontalContentAlignment="Stretch">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0" Width="100" Height="100" Stretch="Uniform">
                                <Image.Source>
                                    <Binding Path="Logo">
                                        <Binding.TargetNullValue>
                                            <BitmapImage UriSource="Res/picture.png" />
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </Image.Source>
                            </Image>

                            <StackPanel Grid.Column="1" Margin="10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding AgentType.Title}" FontSize="18"/>
                                    <TextBlock Text=" | " FontSize="18"/>
                                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>

                                <TextBlock Text="{Binding TotalSales, StringFormat='{}{0} продаж за год'}" Margin="0,5"/>
                                <TextBlock Text="{Binding Phone}"/>
                                <TextBlock Text="{Binding Priority, StringFormat='Приоритетность: {0}'}" Margin="0,5"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="{Binding DiscountPercent, StringFormat='{}{0}%'}" FontSize="20" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>